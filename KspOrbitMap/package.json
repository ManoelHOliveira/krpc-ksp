{
  "name": "ksp-orbit-map",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,frontend -c cyan,green \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "nodemon --watch server --ext py --exec python server/main.py",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
